# 棱镜 (Prism) 后端环境变量示例
# 启动后端：uvicorn main:app --reload --port 8000
PRISM_PORT=8000
PRISM_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
# 分析模型配置池：JSON 字符串，key=模型名（与前端 SettingsPanel 中 model 字段一致），
# value={"endpoint":OpenAI 兼容端点,"key":API Key}。
# endpoint 与 Key 都由后端统一管理，前端只传 model 名，杜绝 SSRF 与 Key 泄漏。
# 示例：{"deepseek-chat":{"endpoint":"https://api.deepseek.com/v1/chat/completions","key":"sk-xxx"},"mimo-v2.5":{"endpoint":"https://api.mimo.com/v1/chat/completions","key":"sk-yyy"}}
PRISM_ANALYZER_API_KEYS=
